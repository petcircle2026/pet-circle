# === PetCircle Backend — Production Environment ===
# DO NOT commit this file with real values.
# In production, set these as environment variables in your hosting provider.
# This file exists only as a reference for which keys are needed.

APP_ENV=production
PYTHON_VERSION=3.11.4

# === OpenAI ===
# OPENAI_API_KEY=  # Set in hosting provider dashboard

# === Supabase ===
# SUPABASE_URL=  # Production Supabase project URL
# SUPABASE_KEY=  # Production anon key
# SUPABASE_SERVICE_ROLE_KEY=  # Production service role key
# SUPABASE_BUCKET_NAME=petcircle-documents

# === WhatsApp Cloud API ===
# WHATSAPP_TOKEN=  # Production WhatsApp token
# WHATSAPP_VERIFY_TOKEN=  # Production verify token
# WHATSAPP_PHONE_NUMBER_ID=  # Production phone number ID
# WHATSAPP_APP_SECRET=  # Production app secret

# === WhatsApp Template Names ===
# Reminder stages (4-stage engine)
# WHATSAPP_TEMPLATE_REMINDER_T7=petcircle_reminder_t7_v1
# WHATSAPP_TEMPLATE_REMINDER_DUE=petcircle_reminder_due_v1
# WHATSAPP_TEMPLATE_REMINDER_D3=petcircle_reminder_d3_v1
# WHATSAPP_TEMPLATE_REMINDER_OVERDUE=petcircle_reminder_overdue_v1
# Nudges
# WHATSAPP_TEMPLATE_NUDGE_VALUE_ADD_PERSONAL=petcircle_nudge_va_personal_v1
# WHATSAPP_TEMPLATE_NUDGE_ENGAGEMENT=petcircle_nudge_engagement_v1
# WHATSAPP_TEMPLATE_NUDGE_BREED=petcircle_nudge_breed_v1
# WHATSAPP_TEMPLATE_NUDGE_BREED_DATA=petcircle_nudge_breed_data_v1
# Transactional
# WHATSAPP_TEMPLATE_CONFLICT=petcircle_conflict_v1
# WHATSAPP_TEMPLATE_ONBOARDING_COMPLETE=petcircle_onboarding_complete_v1
# WHATSAPP_TEMPLATE_ORDER_FULFILLMENT_CHECK=order_fulfillment_check_v1
# WHATSAPP_TEMPLATE_BIRTHDAY=birthday_celebration_v1

# === Admin ===
# ADMIN_SECRET_KEY=  # Generate: python -c "import secrets; print(secrets.token_hex(16))"
# ADMIN_DASHBOARD_PASSWORD=  # A memorable password for admin dashboard login

# === Database ===
# DATABASE_URL=  # Supabase connection string (pooler recommended)

# === Security ===
# ENCRYPTION_KEY=  # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FRONTEND_URL=  # e.g., https://petcircle.vercel.app

# === Feature Flags ===
# AI provider: "claude" (Anthropic) or "openai" (GPT). Defaults to "claude".
AI_PROVIDER=claude
AGENTIC_ORDER_ENABLED=true
